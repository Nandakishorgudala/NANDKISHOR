{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileUploadSettings": {
    "StoragePath": "uploads/documents",
    "MaxFileSizeBytes": 10485760,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "application/pdf"
    ]
  },
  "ClaimUploadSettings": {
    "StoragePath": "uploads/claims",
    "MaxFileSizeBytes": 10485760,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "application/pdf"
    ]
  }
}